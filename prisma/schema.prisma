generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Hospital {
  id         Int      @id @default(autoincrement())
  name       String
  city       String
  state      String
  address    String
  phone      String
  totalBeds  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  beds    Bed[]
  doctors Doctor[]
  admins  Admin[]

  @@map("hospitals")
}

model Bed {
  id         Int       @id @default(autoincrement())
  bedNumber  String
  wardType   String
  status     String    @default("AVAILABLE")
  floor      Int
  hospitalId Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  hospital    Hospital     @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  bedBookings BedBooking[]

  @@unique([hospitalId, bedNumber])
  @@map("beds")
}

model Admin {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("ADMIN")
  hospitalId   Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hospital Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@map("admins")
}

model Doctor {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  specialty  String
  schedule   String
  phone      String
  hospitalId Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  hospital      Hospital       @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  bedBookings   BedBooking[]
  prescriptions Prescription[]
  appointments  Appointment[]

  @@map("doctors")
}

model Patient {
  id          Int      @id @default(autoincrement())
  name        String
  email       String   @unique
  phone       String
  privacyCode String
  bloodType   String
  dateOfBirth DateTime
  role        String   @default("PATIENT")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bedBookings   BedBooking[]
  prescriptions Prescription[]
  appointments  Appointment[]

  @@map("patients")
}

model BedBooking {
  id            Int       @id @default(autoincrement())
  admissionDate DateTime
  dischargeDate DateTime?
  status        String    @default("ACTIVE")
  bedId         Int
  patientId     Int
  doctorId      Int
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bed     Bed     @relation(fields: [bedId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@map("bed_bookings")
}

model Appointment {
  id              Int      @id @default(autoincrement())
  patientId       Int
  doctorId        Int
  specialty       String
  date            DateTime
  status          String   @default("PENDING") // PENDING, ACCEPTED, REJECTED, COMPLETED
  reason          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient         Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor          Doctor         @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  prescriptions   Prescription[]
  messages        Message[]

  @@map("appointments")
}

model Prescription {
  id           Int      @id @default(autoincrement())
  medication   String
  dosage       String
  instructions String
  date         DateTime
  patientId    Int
  doctorId     Int
  appointmentId Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor      Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@map("prescriptions")
}

model Message {
  id            Int      @id @default(autoincrement())
  content       String
  senderId      Int
  senderRole    String   // "PATIENT" or "DOCTOR"
  appointmentId Int
  createdAt     DateTime @default(now())

  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("messages")
}
